    },
    {
      "parameters": {
        "jsCode": "const produtos = items[0].json.produtos;\n\n// Agrupar por categoria\nconst grupos = {};\nfor (const produto of produtos) {\n  const cat = produto.Categoria;\n  if (!grupos[cat]) {\n    grupos[cat] = { \n      Categoria: cat, \n      Total_Itens: 0, \n      Quantidade_Total: 0 \n    };\n  }\n  grupos[cat].Total_Itens += 1;\n  grupos[cat].Quantidade_Total += Number(produto.Quantidade);\n}\n\n// Converter para array de itens\nreturn Object.values(grupos).map(g => ({ json: g }));"
      },
